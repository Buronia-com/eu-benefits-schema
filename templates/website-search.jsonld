{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://example.org/#website",
  "url": "https://example.org/",
  "name": "Example Benefits Helper",
  "publisher": {
    "@id": "https://example.org/#org"
  },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://example.org/?country={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
}
